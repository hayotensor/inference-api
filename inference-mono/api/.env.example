APP_NAME=Inference API
APP_ENV=local
DEBUG=true
API_BASE_URL=http://localhost:8000

DATABASE_URL=postgresql+asyncpg://inference:inference@postgres:5432/inference
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_STORAGE_URL=redis://redis:6379/1
RATE_LIMIT_FAIL_OPEN=true
RATE_LIMIT_ENABLED=true
TOKEN_REVOCATION_FAIL_OPEN=true

JWT_SECRET=replace-with-32-byte-random-secret
JWT_AUDIENCE=fastapi-users:auth
JWT_LIFETIME_SECONDS=900
REFRESH_TOKEN_LIFETIME_DAYS=30
VERIFICATION_TOKEN_SECRET=replace-with-32-byte-random-secret
RESET_PASSWORD_TOKEN_SECRET=replace-with-32-byte-random-secret
OAUTH_STATE_SECRET=replace-with-32-byte-random-secret
SESSION_SECRET=replace-with-32-byte-random-secret
SECRET_PEPPER=replace-with-32-byte-random-secret

CORS_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1,testserver

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

EMAIL_PROVIDER=console
EMAIL_FROM=noreply@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=true
SENDGRID_API_KEY=
RESEND_API_KEY=
AWS_REGION=us-east-1

SMS_PROVIDER=console
DEFAULT_PHONE_REGION=US
PHONE_USER_EMAIL_DOMAIN=phone-users.example.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
API_KEY_DEFAULT_RATE_LIMIT_PER_MINUTE=120

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:8000/billing/success
STRIPE_CANCEL_URL=http://localhost:8000/billing/cancel
STRIPE_CUSTOMER_PORTAL_RETURN_URL=http://localhost:8000/billing
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=

ETHEREUM_RPC_URL=
ETHEREUM_ERC20_CONTRACT_ADDRESS=
ETHEREUM_ERC20_DECIMALS=18
SUBSTRATE_EVM_RPC_URL=
SUBSTRATE_NATIVE_DECIMALS=18

# TOKEN_RESET_MODE: account_creation | calendar_month | weekly
TOKEN_RESET_MODE=account_creation
TOKEN_RESET_DAY=1
TOKEN_RESET_WEEKDAY=0  # 0=Monday; anchor for weekly mode
FREE_MONTHLY_TOKEN_ALLOWANCE=0
WALLET_NONCE_TTL_SECONDS=600

# Subnet-stake weekly quota. The indexer read + tuning live in the inference
# service; the main API only needs the switch (for usage reporting parity).
SUBNET_STAKE_QUOTA_ENABLED=false
