APP_NAME=TEE Inference API
APP_ENV=local
DEBUG=true

DATABASE_URL=postgresql+asyncpg://inference:inference@postgres:5432/inference
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_ENABLED=true
RATE_LIMIT_FAIL_OPEN=true

# Must match the main API's SECRET_PEPPER so API keys and router tokens validate.
SECRET_PEPPER=replace-with-32-byte-random-secret

CORS_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
REQUEST_ID_HEADER=X-Request-ID

ROUTER_RESERVATION_TTL_SECONDS=900
ROUTER_MAX_INPUT_TOKENS=1000000
ROUTER_MAX_OUTPUT_TOKENS=1000000

TOKEN_RESET_MODE=account_creation
TOKEN_RESET_DAY=1
FREE_MONTHLY_TOKEN_ALLOWANCE=0

# Optional peer mesh router endpoint. When set, /v1/inference posts to {MESH_ROUTER_URL}/inference.
MESH_ROUTER_URL=
MESH_REQUEST_TIMEOUT_SECONDS=120
