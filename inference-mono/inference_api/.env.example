APP_NAME=TEE Inference API
APP_ENV=local
DEBUG=true

DATABASE_URL=postgresql+asyncpg://inference:inference@postgres:5432/inference
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_ENABLED=true
RATE_LIMIT_FAIL_OPEN=true

# Must match the main API's SECRET_PEPPER so API keys and router tokens validate.
SECRET_PEPPER=replace-with-32-byte-random-secret

CORS_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
REQUEST_ID_HEADER=X-Request-ID

ROUTER_RESERVATION_TTL_SECONDS=900
ROUTER_MAX_INPUT_TOKENS=1000000
ROUTER_MAX_OUTPUT_TOKENS=1000000

# TOKEN_RESET_MODE: account_creation | calendar_month | weekly
# Use "weekly" to reset the shared usage window every 7 days (subnet-stake quota).
TOKEN_RESET_MODE=account_creation
TOKEN_RESET_DAY=1
TOKEN_RESET_WEEKDAY=0  # 0=Monday; anchor for weekly mode
FREE_MONTHLY_TOKEN_ALLOWANCE=0

# --- Subnet-stake weekly quota (reads the ht-indexer) --------------------- #
# Reward wallets that have continuously delegated to the subnet for >= MIN_DAYS
# with a weekly, stake-proportional inference-token quota. Off by default.
SUBNET_STAKE_QUOTA_ENABLED=false
HT_INDEXER_GRAPHQL_URL=            # e.g. http://localhost:4350/graphql (required when enabled)
HT_INDEXER_TIMEOUT_SECONDS=10
SUBNET_STAKE_SUBNET_ID=           # which subnet's delegation counts (required when enabled)
SUBNET_STAKE_DECIMALS=18          # native-token decimals used to normalize stake
SUBNET_STAKE_MIN_DAYS=30          # minimum continuous stake age to qualify
SUBNET_STAKE_MIN_AMOUNT=0         # minimum normalized stake to qualify at all
SUBNET_STAKE_TOKENS_UNIT=1        # normalized stake per allowance "unit"
SUBNET_STAKE_TOKENS_PER_UNIT=0    # tokens granted per unit (0 => feature grants nothing)
SUBNET_STAKE_WEEKLY_TOKEN_CAP=0   # 0 = uncapped
SUBNET_STAKE_REFRESH_INTERVAL_SECONDS=900  # max unstake-detection lag

# Optional peer mesh router endpoint. When set, /v1/inference posts to {MESH_ROUTER_URL}/inference.
MESH_ROUTER_URL=
MESH_REQUEST_TIMEOUT_SECONDS=120
